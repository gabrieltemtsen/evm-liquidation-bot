# ──────────────────────────────────────────────
# EVM Liquidation Bot — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Chain selection ────────────────────────────
# Options: ethereum | arbitrum | base
CHAIN=ethereum

# ── RPC endpoints (WebSocket) ──────────────────
# Ethereum mainnet (Alchemy / Infura)
ETH_RPC_WS=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETH_RPC_HTTP=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Arbitrum One
ARB_RPC_WS=wss://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ARB_RPC_HTTP=https://arb-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Base
BASE_RPC_WS=wss://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
BASE_RPC_HTTP=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Bot wallet ─────────────────────────────────
# Private key of the wallet that pays gas fees.
# Must hold ETH on the target chain for gas.
# NEVER commit this to git.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ── Deployed contract address ──────────────────
# Set this after running: npm run deploy:mainnet (or :arbitrum / :base)
FLASH_LIQUIDATOR_ADDRESS=

# ── Flashbots (Ethereum mainnet only) ──────────
# Generate at: https://protect.flashbots.net
FLASHBOTS_AUTH_KEY=0xYOUR_FLASHBOTS_KEY_HERE

# ── Profitability thresholds ───────────────────
# Minimum net profit required to execute a liquidation (in ETH)
# 0.005 = balanced default | 0.001 = aggressive | 0.01 = conservative
MIN_PROFIT_ETH=0.005

# Maximum gas price willing to pay (in Gwei)
MAX_GAS_GWEI=50

# ── Bot behaviour ──────────────────────────────
# DRY_RUN=true  → simulate only, no real transactions (safe default)
# DRY_RUN=false → live mode (deploy contract first!)
DRY_RUN=true

# How often to scan positions (milliseconds)
# 30000 = 30s default | 10000 = faster | 60000 = slower (fewer RPC calls)
MONITOR_INTERVAL_MS=30000

# ── Dashboard ──────────────────────────────────
DASHBOARD_PORT=3000

# ── Block explorer API keys (for contract verification) ───
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=

# ── Gas reporter (dev only) ────────────────────
REPORT_GAS=false
CMC_API_KEY=
