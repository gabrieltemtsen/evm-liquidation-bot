{
  "name": "evm-liquidation-bot",
  "version": "1.0.0",
  "description": "Production-ready EVM liquidation bot targeting Aave V3 with Flashbots integration",
  "type": "module",
  "scripts": {
    "start": "node --experimental-vm-modules dist/bot/src/index.js",
    "dev": "tsx bot/src/index.ts",
    "build": "tsc -p tsconfig.json",
    "compile": "hardhat compile --config hardhat.config.cjs",
    "test": "hardhat test --config hardhat.config.cjs",
    "test:fork": "ETH_RPC_HTTP=$ETH_RPC_HTTP hardhat test --config hardhat.config.cjs --network hardhat",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --config hardhat.config.cjs --network mainnet",
    "deploy:arbitrum": "hardhat run scripts/deploy.ts --config hardhat.config.cjs --network arbitrum",
    "deploy:base": "hardhat run scripts/deploy.ts --config hardhat.config.cjs --network base",
    "deploy:local": "hardhat run scripts/deploy.ts --config hardhat.config.cjs --network hardhat",
    "lint": "eslint 'bot/src/**/*.ts'",
    "clean": "rimraf dist cache artifacts"
  },
  "keywords": [
    "defi",
    "liquidation",
    "aave",
    "flashloans",
    "flashbots",
    "ethereum",
    "arbitrage",
    "mev"
  ],
  "author": "gabrieltemtsen",
  "license": "MIT",
  "dependencies": {
    "@aave/contract-helpers": "^1.37.1",
    "@flashbots/ethers-provider-bundle": "^1.0.0",
    "@openzeppelin/contracts": "^5.6.1",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.4",
    "express": "^4.21.2",
    "socket.io": "^4.8.1",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/express": "^5.0.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.10.2",
    "chai": "^4.5.0",
    "hardhat": "^2.22.17",
    "hardhat-gas-reporter": "^1.0.10",
    "rimraf": "^6.0.1",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.2",
    "typechain": "^8.3.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
