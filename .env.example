# ─── RPC Endpoints ────────────────────────────────────────────────────────────
# WebSocket endpoints for the bot monitor
ETH_RPC_WS=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_WS=wss://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_WS=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# HTTP endpoints for Hardhat (optional, derived from WS if not set)
ETH_RPC_HTTP=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_HTTP=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_HTTP=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ─── Wallet ────────────────────────────────────────────────────────────────────
# Bot executor wallet — needs ETH for gas
PRIVATE_KEY=your_private_key_here

# ─── Flashbots ─────────────────────────────────────────────────────────────────
# Used for MEV protection on Ethereum mainnet
# Generate: cast wallet new
FLASHBOTS_AUTH_KEY=your_flashbots_auth_key_here

# ─── Contract (after deploy) ───────────────────────────────────────────────────
FLASH_LIQUIDATOR_ADDRESS=

# ─── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000

# ─── Bot Configuration ─────────────────────────────────────────────────────────
# Target chain: ethereum | arbitrum | base
CHAIN=ethereum

# Minimum profit threshold (in ETH) to execute a liquidation
MIN_PROFIT_ETH=0.005

# Maximum gas price willing to pay (in Gwei)
MAX_GAS_GWEI=50

# Monitor scan interval (milliseconds)
MONITOR_INTERVAL_MS=30000

# Dry run — simulate but don't submit real transactions
# Set to false ONLY after testing thoroughly
DRY_RUN=true

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# ─── Block Explorer API Keys (for contract verification) ───────────────────────
ETHERSCAN_API_KEY=
ARBISCAN_API_KEY=
BASESCAN_API_KEY=

# ─── Gas Reporter ──────────────────────────────────────────────────────────────
REPORT_GAS=false
CMC_API_KEY=
